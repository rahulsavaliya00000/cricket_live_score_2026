<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@color/notif_bg">

    <ImageView
        android:id="@+id/notif_icon_collapsed"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/launcher_icon"
        android:layout_marginEnd="12dp"
        android:contentDescription="CricketBuzz"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_title_collapsed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎁 Free Daily Spin Available!"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/notif_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notif_body_collapsed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to spin the wheel and win rewards! 🏏"
            android:textSize="12sp"
            android:textColor="@color/notif_text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
