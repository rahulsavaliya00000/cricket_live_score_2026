<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#007A4D"
                android:endColor="#00A86B"
                android:angle="135" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#005C38" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00A86B"
                android:endColor="#33C98B"
                android:angle="135" />
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="#007A4D" />
        </shape>
    </item>
</selector>
